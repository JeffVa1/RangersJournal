---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const normalizePath = (path: string) =>
  path.length > 1 ? path.replace(/\/+$/, "") : path;
const activePath = normalizePath(currentPath);

const items = [
  {
    href: "/",
    label: "Home",
    icon: "home",
    active: activePath === "/" || activePath === "/viewer"
  },
  {
    href: "/map",
    label: "Map",
    icon: "map",
    active: activePath === "/map"
  },
  {
    href: "/calendar",
    label: "Calendar",
    icon: "calendar",
    active: activePath === "/calendar"
  },
  {
    href: "/session-recaps",
    label: "Session Recaps",
    icon: "scroll",
    active: activePath === "/session-recaps"
  },
  {
    href: "/character-profiles",
    label: "Character Profiles",
    icon: "users",
    active: activePath === "/character-profiles"
  }
];
---

<nav class="app-sidebar" aria-label="Primary" data-sidebar>
  <button
    class="app-sidebar-toggle"
    type="button"
    aria-label="Open navigation"
    aria-expanded="false"
    data-sidebar-toggle
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M4 7h16" />
      <path d="M4 12h16" />
      <path d="M4 17h16" />
    </svg>
  </button>

  <ul class="app-sidebar-list">
    {
      items.map((item) => (
        <li>
          <a
            class="app-sidebar-link"
            href={item.href}
            aria-current={item.active ? "page" : undefined}
          >
            <span class="app-sidebar-icon" aria-hidden="true">
              {item.icon === "home" && (
                <svg viewBox="0 0 24 24">
                  <path d="m3 11 9-8 9 8" />
                  <path d="M5 10v10h14V10" />
                  <path d="M9 20v-6h6v6" />
                </svg>
              )}
              {item.icon === "map" && (
                <svg viewBox="0 0 24 24">
                  <path d="m3 6 6-2 6 2 6-2v14l-6 2-6-2-6 2V6Z" />
                  <path d="M9 4v14" />
                  <path d="M15 6v14" />
                </svg>
              )}
              {item.icon === "calendar" && (
                <svg viewBox="0 0 24 24">
                  <path d="M7 3v4" />
                  <path d="M17 3v4" />
                  <path d="M4 9h16" />
                  <rect x="4" y="5" width="16" height="16" rx="2" />
                </svg>
              )}
              {item.icon === "scroll" && (
                <svg viewBox="0 0 24 24">
                  <path d="M8 21h8" />
                  <path d="M8 21a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3h9a2 2 0 0 1 2 2v13a3 3 0 0 0 3 3" />
                  <path d="M8 21a3 3 0 0 0 3-3V5a2 2 0 0 0-2-2" />
                  <path d="M12 8h4" />
                  <path d="M12 12h4" />
                </svg>
              )}
              {item.icon === "users" && (
                <svg viewBox="0 0 24 24">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                  <circle cx="9.5" cy="7" r="4" />
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
              )}
            </span>
            <span class="app-sidebar-label">{item.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  const sidebar = document.querySelector("[data-sidebar]");
  const toggle = document.querySelector("[data-sidebar-toggle]");

  const setExpanded = (isExpanded) => {
    sidebar?.classList.toggle("is-expanded", isExpanded);
    toggle?.setAttribute("aria-expanded", String(isExpanded));
    toggle?.setAttribute(
      "aria-label",
      isExpanded ? "Close navigation" : "Open navigation"
    );
  };

  toggle?.addEventListener("click", (event) => {
    event.stopPropagation();
    setExpanded(!sidebar?.classList.contains("is-expanded"));
  });

  sidebar?.addEventListener("click", () => setExpanded(true));

  document.addEventListener("pointerdown", (event) => {
    if (!(event.target instanceof Node) || sidebar?.contains(event.target)) {
      return;
    }

    setExpanded(false);
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setExpanded(false);
    }
  });
</script>
